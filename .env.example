# Nashik Kumbh Navigator - Example Environment Configuration
# Copy this file to .env and replace the placeholder values with your project credentials.
# NEVER commit your actual .env file to version control.

# Google Maps Platform (Android & iOS SDK API Key)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Firebase Project Configuration (Production / Staging)
FIREBASE_PROJECT_ID=nashik-kumbh-navigator-2027
FIREBASE_API_KEY_ANDROID=AIzaSyYOUR_ANDROID_FIREBASE_API_KEY_HERE
FIREBASE_APP_ID_ANDROID=1:1234567890:android:abcdef1234567890
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_STORAGE_BUCKET=nashik-kumbh-navigator-2027.appspot.com

# Emergency & Civic Alert API Endpoints (Optional / Overrides)
EMERGENCY_DISPATCH_API_URL=https://api.nashikkumbh2027.gov.in/v1/sos
CROWD_HEATMAP_SOCKET_URL=wss://live.nashikkumbh2027.gov.in/ws/crowd
